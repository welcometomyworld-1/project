# Copy to .env and fill values. Never commit .env with real secrets.

# --- OTP mode: "real" = SMS + email must be configured. "demo" = OTP on screen only (local testing) ---
NYAYAFLOW_OTP_MODE=real

# ========== REAL SMS (choose ONE) ==========
# Twilio (https://console.twilio.com)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# OR Fast2SMS India (https://www.fast2sms.com/)
# FAST2SMS_API_KEY=
# FAST2SMS_SENDER_ID=TXTIND
# FAST2SMS_ROUTE=q

# ========== REAL EMAIL (SMTP) ==========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SSL=false
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=your@gmail.com
